<%- include('partials/header') %>

<!-- Main Container -->
<div class="min-h-screen flex flex-col">
  
  <!-- Header -->
  <header class="bg-dark-800/80 backdrop-blur-lg border-b border-dark-700 sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-gradient-to-br from-brand-400 to-brand-600 rounded-full flex items-center justify-center">
          <span class="text-white font-bold text-lg">L</span>
        </div>
        <div>
          <h1 class="text-lg font-bold text-white"><%= brand.name %></h1>
          <p class="text-xs text-dark-300">Social Media Manager</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <a href="/gallery" class="px-3 py-2 rounded-lg bg-dark-700 hover:bg-dark-600 text-dark-200 hover:text-white transition-colors text-sm">
          Gallery
        </a>
        <a href="/settings" class="px-3 py-2 rounded-lg bg-dark-700 hover:bg-dark-600 text-dark-200 hover:text-white transition-colors text-sm">
          Settings
        </a>
        <form method="POST" action="/auth/logout" class="hidden sm:block">
          <button type="submit" class="px-3 py-2 rounded-lg bg-red-500/20 hover:bg-red-500/30 text-red-300 border border-red-500/30 transition-colors text-sm">Đăng xuất</button>
        </form>
        <div class="text-xs text-dark-400 hidden sm:block">
          <%= brand.phone %>
        </div>
        <button type="button" id="settingsBtn" class="p-2 rounded-lg bg-dark-700 hover:bg-dark-600 text-dark-300 hover:text-white transition-colors" title="Cài đặt AI">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Content -->
  <main class="flex-1 max-w-2xl w-full mx-auto px-4 py-6 sm:py-10">

    <div id="serverToastError"
      data-error="<%= typeof toastError !== 'undefined' && toastError ? toastError.replace(/"/g, '&quot;') : '' %>"
      class="hidden"></div>
    
    <!-- Title -->
    <div class="text-center mb-8">
      <h2 class="text-2xl sm:text-3xl font-display font-bold text-white mb-2">Tạo Bài Viết Mới</h2>
      <p class="text-dark-300 text-sm">AI sẽ tự động xử lý ảnh, tạo caption và đăng bài</p>
    </div>

    <% if (error) { %>
    <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 mb-6">
      <div class="flex items-center space-x-2">
        <svg class="w-5 h-5 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="text-red-300 text-sm"><%= error %></p>
      </div>
    </div>
    <% } %>

    <% if (success) { %>
    <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 mb-6">
      <div class="flex items-center space-x-2">
        <svg class="w-5 h-5 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="text-green-300 text-sm"><%= success %></p>
      </div>
    </div>
    <% } %>

    <!-- Form -->
    <form action="/create" method="POST" enctype="multipart/form-data" id="postForm" class="space-y-6">
      
      <!-- Post Type -->
      <div class="space-y-3">
        <label class="block text-sm font-semibold text-dark-200">
          Loại bài viết <span class="text-red-400">*</span>
        </label>
        <div class="grid grid-cols-3 gap-2 sm:gap-3">
          <label class="post-type-card group cursor-pointer">
            <input type="radio" name="postType" value="BA" class="sr-only peer" required>
            <div class="bg-dark-800 border-2 border-dark-600 rounded-xl p-3 sm:p-4 text-center transition-all duration-200 peer-checked:border-brand-400 peer-checked:bg-brand-400/10 hover:border-dark-400 group-active:scale-95">
              <div class="text-xl sm:text-2xl mb-1 sm:mb-2">✨</div>
              <div class="text-xs sm:text-sm font-semibold text-white">Before/After</div>
            </div>
          </label>
          <label class="post-type-card group cursor-pointer">
            <input type="radio" name="postType" value="Review" class="sr-only peer">
            <div class="bg-dark-800 border-2 border-dark-600 rounded-xl p-3 sm:p-4 text-center transition-all duration-200 peer-checked:border-brand-400 peer-checked:bg-brand-400/10 hover:border-dark-400 group-active:scale-95">
              <div class="text-xl sm:text-2xl mb-1 sm:mb-2">💬</div>
              <div class="text-xs sm:text-sm font-semibold text-white">Review</div>
            </div>
          </label>
          <label class="post-type-card group cursor-pointer">
            <input type="radio" name="postType" value="BTS" class="sr-only peer">
            <div class="bg-dark-800 border-2 border-dark-600 rounded-xl p-3 sm:p-4 text-center transition-all duration-200 peer-checked:border-brand-400 peer-checked:bg-brand-400/10 hover:border-dark-400 group-active:scale-95">
              <div class="text-xl sm:text-2xl mb-1 sm:mb-2">🎬</div>
              <div class="text-xs sm:text-sm font-semibold text-white">BTS</div>
            </div>
          </label>
          <label class="post-type-card group cursor-pointer">
            <input type="radio" name="postType" value="Promo" class="sr-only peer">
            <div class="bg-dark-800 border-2 border-dark-600 rounded-xl p-3 sm:p-4 text-center transition-all duration-200 peer-checked:border-brand-400 peer-checked:bg-brand-400/10 hover:border-dark-400 group-active:scale-95">
              <div class="text-xl sm:text-2xl mb-1 sm:mb-2">🏷️</div>
              <div class="text-xs sm:text-sm font-semibold text-white">Promo</div>
            </div>
          </label>
          <label class="post-type-card group cursor-pointer">
            <input type="radio" name="postType" value="Spotlight" class="sr-only peer">
            <div class="bg-dark-800 border-2 border-dark-600 rounded-xl p-3 sm:p-4 text-center transition-all duration-200 peer-checked:border-brand-400 peer-checked:bg-brand-400/10 hover:border-dark-400 group-active:scale-95">
              <div class="text-xl sm:text-2xl mb-1 sm:mb-2">⭐</div>
              <div class="text-xs sm:text-sm font-semibold text-white">Spotlight</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Post Title -->
      <div class="space-y-2">
        <label for="title" class="block text-sm font-semibold text-dark-200">
          Tên bài viết <span class="text-red-400">*</span>
        </label>
        <input 
          type="text" id="title" name="title" required
          placeholder="VD: Nối mi Classic - Khách chị Hương"
          class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-3 text-white placeholder-dark-400 focus:outline-none focus:border-brand-400 focus:ring-1 focus:ring-brand-400 transition-colors text-sm"
        >
      </div>

      <!-- Post Content (Optional) -->
      <div class="space-y-2">
        <label for="content" class="block text-sm font-semibold text-dark-200">
          Nội dung bài <span class="text-dark-400 font-normal">(tuỳ chọn)</span>
        </label>
        <textarea 
          id="content" name="content" rows="3"
          placeholder="Mô tả thêm về bài viết, AI sẽ dùng thông tin này để tạo caption..."
          class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-3 text-white placeholder-dark-400 focus:outline-none focus:border-brand-400 focus:ring-1 focus:ring-brand-400 transition-colors text-sm resize-none"
        ></textarea>
      </div>

      <!-- File Upload -->
      <div class="space-y-2">
        <label class="block text-sm font-semibold text-dark-200">
          Ảnh / Video <span class="text-red-400">*</span>
        </label>
        <div class="upload-zone relative" id="uploadZone">
          <input 
            type="file" id="media" name="media" accept="image/*,video/*" required
            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
          >
          <div class="bg-dark-800 border-2 border-dashed border-dark-600 rounded-xl p-8 text-center transition-all duration-200 hover:border-brand-400 hover:bg-dark-800/50" id="uploadContent">
            <div class="upload-icon mx-auto mb-3 text-dark-400">
              <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <p class="text-sm text-dark-300 mb-1">Nhấn để chọn hoặc kéo thả file vào đây</p>
            <p class="text-xs text-dark-500">JPG, PNG, GIF, WEBP, MP4 (tối đa 50MB)</p>
          </div>
          <div class="hidden" id="previewContainer">
            <div class="relative bg-dark-800 rounded-xl overflow-hidden">
              <img id="imagePreview" class="w-full max-h-64 object-contain" src="" alt="Preview">
              <button type="button" id="removeFile" class="absolute top-2 right-2 bg-red-500 hover:bg-red-600 text-white rounded-full w-8 h-8 flex items-center justify-center transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
              <div class="absolute bottom-2 left-2 bg-dark-900/80 px-3 py-1 rounded-lg">
                <span class="text-xs text-dark-200" id="fileName">file.jpg</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer Contact Toggle -->
      <div class="space-y-3 bg-dark-800/50 rounded-xl p-4 border border-dark-700">
        <h3 class="text-sm font-semibold text-dark-200">Footer Contact trên ảnh AI</h3>
        <label class="flex items-center justify-between gap-3 cursor-pointer">
          <div>
            <p class="text-sm text-white">Thêm Address + Phone vào footer ảnh</p>
            <p class="text-xs text-dark-500">Bật: AI bắt buộc render footer contact. Tắt: AI không render footer contact.</p>
          </div>
          <input type="checkbox" name="includeFooterContact" value="on" checked class="w-5 h-5 accent-brand-500" />
        </label>
      </div>

      <!-- Logo & QR Position -->
      <div class="space-y-3 bg-dark-800/50 rounded-xl p-4 border border-dark-700">
        <h3 class="text-sm font-semibold text-dark-200 flex items-center space-x-2">
          <svg class="w-4 h-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
          </svg>
          <span>Vị trí Logo & QR Code</span>
        </h3>
        <div class="grid grid-cols-2 gap-4">
          <!-- Logo Position -->
          <div class="space-y-2">
            <label class="block text-xs font-medium text-dark-300">Logo</label>
            <select name="logoPosition" class="w-full bg-dark-900 border border-dark-600 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-brand-400">
              <option value="bottom-left" selected>Cuối trái (mặc định)</option>
              <option value="bottom-right">Cuối phải</option>
              <option value="top-left">Trên trái</option>
              <option value="top-right">Trên phải</option>
            </select>
          </div>
          <!-- QR Position -->
          <div class="space-y-2">
            <label class="block text-xs font-medium text-dark-300">QR Code</label>
            <select name="qrPosition" class="w-full bg-dark-900 border border-dark-600 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-brand-400">
              <option value="bottom-right" selected>Cuối phải (mặc định)</option>
              <option value="bottom-left">Cuối trái</option>
              <option value="top-left">Trên trái</option>
              <option value="top-right">Trên phải</option>
            </select>
          </div>
        </div>
        <p class="text-xs text-dark-500">Logo & QR sẽ được chèn vào ảnh tại vị trí bạn chọn. Đảm bảo file logo.png/jpg và qr.png nằm trong thư mục public/assets/</p>
      </div>

      <!-- Hidden inputs for AI model selection (populated from localStorage by JS) -->
      <input type="hidden" name="imageModel" id="hiddenImageModel" value="">
      <input type="hidden" name="textModel" id="hiddenTextModel" value="">

      <!-- Submit Button -->
      <button 
        type="submit" id="submitBtn"
        class="w-full bg-gradient-to-r from-brand-500 to-brand-400 hover:from-brand-600 hover:to-brand-500 text-white font-semibold py-4 rounded-xl transition-all duration-200 active:scale-[0.98] shadow-lg shadow-brand-500/20 text-sm sm:text-base"
      >
        <span class="flex items-center justify-center space-x-2">
          <span id="submitText">Tạo bài viết với AI</span>
          <svg class="w-5 h-5 animate-spin hidden" id="submitSpinner" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </span>
      </button>

      <!-- Active model indicator -->
      <div class="text-center mt-3" id="activeModelInfo">
        <p class="text-xs text-dark-500">Model: <span id="activeModelLabel" class="text-dark-400">Default</span></p>
      </div>
    </form>

    <!-- Workflow Steps -->
    <div class="mt-10 bg-dark-800/50 rounded-xl p-6 border border-dark-700">
      <h3 class="text-sm font-semibold text-dark-200 mb-4">Quy trình xử lý</h3>
      <div class="space-y-3">
        <div class="flex items-start space-x-3">
          <div class="w-6 h-6 bg-brand-400/20 text-brand-400 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">1</div>
          <div>
            <p class="text-sm text-white font-medium">Upload ảnh</p>
            <p class="text-xs text-dark-400">Chọn ảnh gốc và loại bài viết</p>
          </div>
        </div>
        <div class="flex items-start space-x-3">
          <div class="w-6 h-6 bg-brand-400/20 text-brand-400 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">2</div>
          <div>
            <p class="text-sm text-white font-medium">AI Thiết kế ảnh</p>
            <p class="text-xs text-dark-400">Gemini AI tạo ảnh thiết kế hoàn chỉnh từ ảnh gốc + thêm logo & QR</p>
          </div>
        </div>
        <div class="flex items-start space-x-3">
          <div class="w-6 h-6 bg-brand-400/20 text-brand-400 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">3</div>
          <div>
            <p class="text-sm text-white font-medium">AI Tạo Caption</p>
            <p class="text-xs text-dark-400">Gemini AI soạn nội dung, hashtag theo loại bài viết</p>
          </div>
        </div>
        <div class="flex items-start space-x-3">
          <div class="w-6 h-6 bg-brand-400/20 text-brand-400 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">4</div>
          <div>
            <p class="text-sm text-white font-medium">Duyệt & Đăng bài</p>
            <p class="text-xs text-dark-400">Preview → Telegram duyệt → tự động đăng Facebook & Instagram</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Service Status (loaded via API) -->
    <div class="mt-4 bg-dark-800/50 rounded-xl p-4 border border-dark-700" id="homeServiceStatus">
      <h4 class="text-xs font-semibold text-dark-300 uppercase tracking-wider mb-3">Trạng thái kết nối</h4>
      <div class="flex flex-wrap gap-2" id="statusBadges">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-dark-700 text-dark-400 border border-dark-600">
          <span class="w-1.5 h-1.5 rounded-full bg-dark-500 animate-pulse"></span>
          Đang kiểm tra...
        </span>
      </div>
      <div id="statusWarnings" class="hidden mt-3 p-2.5 bg-yellow-500/10 border border-yellow-500/20 rounded-lg">
        <p class="text-xs text-yellow-400/90" id="statusWarningText"></p>
      </div>
    </div>
  </main>

  <!-- Settings Modal (Slide-in Panel) -->
  <div id="settingsModal" class="fixed inset-0 z-[60] hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="settingsOverlay"></div>
    <div class="absolute right-0 top-0 h-full w-full max-w-md bg-dark-800 border-l border-dark-700 shadow-2xl transform translate-x-full transition-transform duration-300 ease-out overflow-y-auto" id="settingsPanel">
      <div class="p-6">
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-bold text-white flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            AI Settings
          </h3>
          <button type="button" id="settingsClose" class="p-2 rounded-lg hover:bg-dark-700 text-dark-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <!-- Loading state -->
        <div id="settingsLoading" class="flex flex-col items-center justify-center py-12">
          <svg class="w-8 h-8 animate-spin text-brand-400 mb-3" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <p class="text-sm text-dark-400">Loading models...</p>
        </div>

        <!-- Settings content (hidden until loaded) -->
        <div id="settingsContent" class="hidden">
          <!-- Image Model -->
          <div class="space-y-2 mb-6">
            <label class="block text-sm font-semibold text-dark-200">Image Model</label>
            <select id="settingImageModel" class="w-full bg-dark-900 border border-dark-600 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-brand-400 transition-colors">
              <option value="">-- Server default --</option>
            </select>
            <p class="text-xs text-dark-500">Model dùng tạo ảnh thiết kế từ Gemini AI</p>
          </div>

          <!-- Text Model -->
          <div class="space-y-2 mb-6">
            <label class="block text-sm font-semibold text-dark-200">Text Model</label>
            <select id="settingTextModel" class="w-full bg-dark-900 border border-dark-600 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-brand-400 transition-colors">
              <option value="">-- Server default --</option>
            </select>
            <p class="text-xs text-dark-500">Model dùng tạo caption bài viết</p>
          </div>

          <!-- Current defaults info -->
          <div class="bg-dark-900/50 rounded-lg p-4 border border-dark-700 mb-6">
            <h4 class="text-xs font-semibold text-dark-400 uppercase tracking-wider mb-2">Server Defaults</h4>
            <div class="space-y-1">
              <p class="text-xs text-dark-300"><span class="text-dark-500">Image:</span> <span id="serverDefaultImage">-</span></p>
              <p class="text-xs text-dark-300"><span class="text-dark-500">Text:</span> <span id="serverDefaultText">-</span></p>
            </div>
          </div>

          <!-- Error state -->
          <div id="settingsError" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 mb-6">
            <p class="text-xs text-red-400" id="settingsErrorText"></p>
          </div>

          <!-- Save / Reset -->
          <div class="flex gap-3">
            <button type="button" id="settingsReset" class="flex-1 bg-dark-700 hover:bg-dark-600 text-white font-medium py-3 rounded-xl transition-colors text-sm">
              Reset defaults
            </button>
            <button type="button" id="settingsSave" class="flex-1 bg-gradient-to-r from-brand-500 to-brand-400 hover:from-brand-600 hover:to-brand-500 text-white font-medium py-3 rounded-xl transition-all text-sm">
              Save
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="bg-dark-800/50 border-t border-dark-700 py-4">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-xs text-dark-400"><%= brand.name %> &copy; 2026 | <%= brand.website %></p>
    </div>
  </footer>
</div>

<%- include('partials/footer') %>
