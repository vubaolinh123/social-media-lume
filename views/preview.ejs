<%- include('partials/header') %>

<div class="min-h-screen flex flex-col">
  
  <!-- Header -->
  <header class="bg-dark-800/80 backdrop-blur-lg border-b border-dark-700 sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <a href="/" class="flex items-center space-x-3 hover:opacity-80 transition-opacity">
          <div class="w-10 h-10 bg-gradient-to-br from-brand-400 to-brand-600 rounded-full flex items-center justify-center">
            <span class="text-white font-bold text-lg">L</span>
          </div>
          <div>
            <h1 class="text-lg font-bold text-white"><%= brand.name %></h1>
            <p class="text-xs text-dark-300">Xem trước bài viết</p>
          </div>
        </a>
      </div>
      <div class="flex items-center gap-2">
        <a href="/gallery" class="px-3 py-1 bg-dark-700 hover:bg-dark-600 text-dark-200 text-xs font-medium rounded-full transition-colors">Mở Gallery</a>
        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-400 text-xs font-medium rounded-full">Chờ duyệt</span>
      </div>
    </div>
  </header>

  <main class="flex-1 max-w-2xl w-full mx-auto px-4 py-6 sm:py-10">
    
    <div class="text-center mb-8">
      <h2 class="text-2xl sm:text-3xl font-display font-bold text-white mb-2">Xem Trước Bài Viết</h2>
      <p class="text-dark-300 text-sm">Kiểm tra nội dung trước khi đăng</p>
    </div>

    <div id="serverNotices"
      data-warn="<%= notifications?.warnMessage ? notifications.warnMessage.replace(/"/g, '&quot;') : '' %>"
      data-error="<%= notifications?.errorMessage ? notifications.errorMessage.replace(/"/g, '&quot;') : '' %>"
      data-post-id="<%= post.id %>"
      data-processing="<%= post.processing ? '1' : '0' %>"
      class="hidden"></div>

    <!-- Service Status Badges -->
    <div class="bg-dark-800/50 rounded-xl border border-dark-700 p-4 mb-6" id="serviceStatus">
      <h4 class="text-xs font-semibold text-dark-300 uppercase tracking-wider mb-3">Trạng thái dịch vụ</h4>
      <div class="flex flex-wrap gap-2">
        <% if (typeof services !== 'undefined') { %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium <%= services.gemini ? 'bg-green-500/15 text-green-400 border border-green-500/30' : 'bg-red-500/15 text-red-400 border border-red-500/30' %>">
            <span class="w-1.5 h-1.5 rounded-full <%= services.gemini ? 'bg-green-400' : 'bg-red-400' %>"></span>
            Gemini AI
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium <%= services.facebook ? 'bg-green-500/15 text-green-400 border border-green-500/30' : 'bg-yellow-500/15 text-yellow-400 border border-yellow-500/30' %>">
            <span class="w-1.5 h-1.5 rounded-full <%= services.facebook ? 'bg-green-400' : 'bg-yellow-400' %>"></span>
            Facebook
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium <%= services.instagram ? 'bg-green-500/15 text-green-400 border border-green-500/30' : 'bg-yellow-500/15 text-yellow-400 border border-yellow-500/30' %>">
            <span class="w-1.5 h-1.5 rounded-full <%= services.instagram ? 'bg-green-400' : 'bg-yellow-400' %>"></span>
            Instagram
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium <%= services.telegram ? 'bg-green-500/15 text-green-400 border border-green-500/30' : 'bg-yellow-500/15 text-yellow-400 border border-yellow-500/30' %>">
            <span class="w-1.5 h-1.5 rounded-full <%= services.telegram ? 'bg-green-400' : 'bg-yellow-400' %>"></span>
            Telegram
          </span>
        <% } %>
      </div>
      <% if (typeof services !== 'undefined' && (!services.facebook || !services.telegram)) { %>
        <div class="mt-3 p-2.5 bg-yellow-500/10 border border-yellow-500/20 rounded-lg">
          <p class="text-xs text-yellow-400/90">
            <% if (!services.facebook && !services.telegram) { %>
              Chưa cấu hình Facebook & Telegram. Bài viết sẽ chỉ được tạo ảnh + caption, không đăng lên mạng xã hội.
            <% } else if (!services.facebook) { %>
              Chưa cấu hình Facebook. Bài viết sẽ không được đăng lên Facebook & Instagram.
            <% } else if (!services.telegram) { %>
              Chưa cấu hình Telegram. Bài viết sẽ được đăng trực tiếp, không qua bước duyệt.
            <% } %>
          </p>
        </div>
      <% } %>
    </div>

    <!-- Post Info -->
    <div class="bg-dark-800 rounded-xl border border-dark-700 overflow-hidden mb-6">
      <div class="p-4 border-b border-dark-700">
        <div class="flex items-center justify-between">
          <div>
            <span class="text-xs text-brand-400 font-semibold uppercase"><%= post.postType %></span>
            <h3 class="text-lg font-bold text-white mt-1"><%= post.title %></h3>
          </div>
        </div>
      </div>

      <!-- Side-by-side Preview -->
      <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="bg-dark-900 border border-dark-700 rounded-xl p-3">
          <p class="text-xs text-dark-400 mb-2">Ảnh gốc</p>
          <img src="<%= originalSrc %>" alt="Original" class="w-full rounded-lg">
        </div>
        <div class="bg-dark-900 border border-dark-700 rounded-xl p-3 relative">
          <p class="text-xs text-dark-400 mb-2">Ảnh AI</p>
          <% if (imageSrc) { %>
            <img id="previewAiImage" src="<%= imageSrc %>" alt="Processed image" class="w-full rounded-lg">
          <% } else { %>
            <img id="previewAiImage" src="" alt="Processed image" class="w-full rounded-lg hidden">
            <div id="previewAiPending" class="rounded-lg border border-dashed border-yellow-500/40 bg-yellow-500/10 p-6 text-yellow-300 text-sm">Đang tạo ảnh AI... Vui lòng chờ hoặc mở Gallery để theo dõi realtime</div>
          <% } %>
          <% if (post.aiGenerated) { %>
            <div class="absolute top-7 right-6 bg-green-500/90 text-white text-xs px-3 py-1 rounded-full font-medium flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
              AI Generated
            </div>
          <% } %>

          <% if (post.generationStatus === 'processing') { %>
            <div class="mt-3 text-xs text-yellow-300 bg-yellow-500/10 border border-yellow-500/30 rounded-lg p-2">
              Ảnh đang được tạo ở nền. UI sẽ tự cập nhật ngay khi hoàn tất.
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Caption Preview -->
    <div class="bg-dark-800 rounded-xl border border-dark-700 overflow-hidden mb-6">
      <div class="p-4 border-b border-dark-700 flex items-center justify-between">
        <h3 class="text-sm font-semibold text-dark-200">Caption</h3>
        <button 
          type="button" 
          id="regenerateBtn"
          data-post-id="<%= post.id %>"
          class="text-xs text-brand-400 hover:text-brand-300 font-medium flex items-center space-x-1 transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          <span>Tạo lại caption</span>
        </button>
      </div>
      <div class="p-4">
        <textarea 
          id="captionText" 
          class="w-full bg-dark-900 border border-dark-600 rounded-lg px-4 py-3 text-white text-sm focus:outline-none focus:border-brand-400 resize-none min-h-[200px]"
        ><%= post.caption %></textarea>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="/" class="flex-1 bg-dark-700 hover:bg-dark-600 text-white font-semibold py-4 rounded-xl transition-colors text-center text-sm">
        Huỷ bỏ
      </a>
      <button 
        type="button" 
        id="approveBtn"
        data-post-id="<%= post.id %>"
        class="flex-1 bg-gradient-to-r from-green-600 to-green-500 hover:from-green-700 hover:to-green-600 text-white font-semibold py-4 rounded-xl transition-all duration-200 active:scale-[0.98] shadow-lg shadow-green-500/20 text-sm sm:text-base"
      >
        <span class="flex items-center justify-center space-x-2">
          <span id="approveText">
            <% if (typeof services !== 'undefined' && services.telegram && services.facebook) { %>
              Duyệt & Đăng bài
            <% } else if (typeof services !== 'undefined' && !services.telegram && services.facebook) { %>
              Đăng bài trực tiếp
            <% } else if (typeof services !== 'undefined' && services.telegram && !services.facebook) { %>
              Gửi duyệt Telegram
            <% } else { %>
              Xác nhận
            <% } %>
          </span>
          <svg class="w-5 h-5 animate-spin hidden" id="approveSpinner" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </span>
      </button>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-dark-800/50 border-t border-dark-700 py-4">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-xs text-dark-400"><%= brand.name %> &copy; 2026 | <%= brand.website %></p>
    </div>
  </footer>
</div>

<%- include('partials/footer') %>
