<%- include('partials/header') %>

<div class="min-h-screen flex flex-col">
  <header class="bg-dark-800/80 backdrop-blur-lg border-b border-dark-700 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-gradient-to-br from-brand-400 to-brand-600 rounded-full flex items-center justify-center">
          <span class="text-white font-bold text-lg">L</span>
        </div>
        <div>
          <h1 class="text-lg font-bold text-white"><%= brand.name %></h1>
          <p class="text-xs text-dark-300">Gallery ảnh gốc & ảnh AI</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <a href="/" class="px-3 py-2 rounded-lg bg-dark-700 hover:bg-dark-600 text-sm text-white transition-colors">Tạo bài mới</a>
        <form method="POST" action="/auth/logout">
          <button type="submit" class="px-3 py-2 rounded-lg bg-red-500/20 hover:bg-red-500/30 text-sm text-red-300 border border-red-500/30 transition-colors">Đăng xuất</button>
        </form>
      </div>
    </div>
  </header>

  <main class="flex-1 max-w-6xl w-full mx-auto px-4 py-6 sm:py-8">
    <div class="mb-6 flex items-end justify-between gap-3">
      <div>
        <h2 class="text-2xl sm:text-3xl font-display font-bold text-white">Thư viện bài đã tạo</h2>
        <p class="text-sm text-dark-300 mt-1">Mỗi item hiển thị ảnh gốc bên trái và ảnh AI bên phải</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/settings" class="px-3 py-2 rounded-lg bg-dark-700 hover:bg-dark-600 text-sm text-white transition-colors">Settings</a>
        <button id="refreshGalleryBtn" type="button" class="px-3 py-2 rounded-lg bg-brand-500 hover:bg-brand-600 text-sm text-white transition-colors">Làm mới</button>
      </div>
      <span class="text-xs text-dark-400">Tổng: <span id="galleryCount"><%= items.length %></span> item</span>
    </div>

    <% if (items.length === 0) { %>
      <div class="bg-dark-800 border border-dark-700 rounded-2xl p-8 text-center">
        <p class="text-dark-300">Chưa có ảnh nào. Hãy tạo ảnh mới từ trang chính.</p>
        <a href="/" class="inline-block mt-4 px-4 py-2 rounded-lg bg-brand-500 hover:bg-brand-600 text-white text-sm">Đi tới trang tạo bài</a>
      </div>
    <% } %>

    <div class="space-y-6" id="galleryList">
      <% items.forEach((item) => { %>
        <article class="bg-dark-800 border border-dark-700 rounded-2xl overflow-hidden" data-post-id="<%= item.id %>">
          <div class="p-4 border-b border-dark-700 flex items-start justify-between gap-3">
            <div>
              <p class="text-xs uppercase text-brand-400 font-semibold"><%= item.postType %></p>
              <h3 class="text-lg font-bold text-white mt-1"><%= item.title %></h3>
              <p class="text-xs text-dark-400 mt-1">Similarity: <%= item.similarityScore ?? 'N/A' %> | Status: <span class="generation-status"><%= item.generationStatus %></span></p>
            </div>
            <span class="text-xs px-2 py-1 rounded-full bg-dark-700 text-dark-300"><%= new Date(item.createdAt).toLocaleString('vi-VN') %></span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-0 md:gap-4 p-4">
            <div class="bg-dark-900 border border-dark-700 rounded-xl p-3">
              <p class="text-xs text-dark-400 mb-2">Ảnh gốc</p>
              <img src="<%= item.originalSrc %>" alt="Original image" class="w-full rounded-lg border border-dark-700" />
            </div>

            <div class="bg-dark-900 border border-dark-700 rounded-xl p-3">
              <p class="text-xs text-dark-400 mb-2">Ảnh AI</p>
              <% if (item.generatedSrc) { %>
                <img src="<%= item.generatedSrc %>" alt="Generated image" class="generated-image w-full rounded-lg border border-dark-700" />
              <% } else { %>
                <img src="" alt="Generated image" class="generated-image w-full rounded-lg border border-dark-700 hidden" />
                <div class="generated-pending rounded-lg border border-dashed border-yellow-500/40 bg-yellow-500/10 p-6 text-yellow-300 text-sm">
                  <% if (item.generationStatus === 'processing') { %>
                    Đang tạo ảnh AI... sẽ tự cập nhật khi xong.
                  <% } else { %>
                    Không có ảnh AI hợp lệ.
                  <% } %>
                </div>
              <% } %>
              <% if (item.modelError) { %>
                <div class="mt-2 text-xs text-red-300 bg-red-500/10 border border-red-500/30 rounded-lg p-2">Model error: <%= item.modelError %></div>
              <% } %>
            </div>
          </div>

          <div class="p-4 border-t border-dark-700">
            <div class="flex flex-wrap gap-2">
              <button type="button" class="btn-post-facebook px-3 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm" data-post-id="<%= item.id %>">Đăng Facebook</button>
              <button type="button" class="btn-post-instagram px-3 py-2 rounded-lg bg-pink-600 hover:bg-pink-700 text-white text-sm" data-post-id="<%= item.id %>">Đăng Instagram</button>
              <button type="button" class="btn-delete-post px-3 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm" data-post-id="<%= item.id %>">Xóa ảnh</button>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </main>

  <footer class="bg-dark-800/50 border-t border-dark-700 py-4">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <p class="text-xs text-dark-400"><%= brand.name %> &copy; 2026 | <%= brand.website %></p>
    </div>
  </footer>
</div>

<script src="/js/gallery.js"></script>
<%- include('partials/footer') %>
